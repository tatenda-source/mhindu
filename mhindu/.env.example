# ── Vercel AI Gateway ────────────────────────────────────────────────────────
# Source: Vercel Marketplace → AI Gateway integration.
# Prefer OIDC (automatic token rotation) over a long-lived key.
# Without this, /api/scout returns a canned FAW demo detection so the UI
# flow is fully testable offline.
AI_GATEWAY_API_KEY=

# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Source: Vercel Marketplace → Neon integration.
# Vercel injects a per-environment branch URL automatically:
#   production  → main Neon branch
#   preview     → Neon branch named after the PR
#   development → pulled via `vercel env pull .env.local`
# Migrations: `pnpm drizzle-kit migrate` (requires DB to be reachable).
DATABASE_URL=

# ── Vercel Blob ───────────────────────────────────────────────────────────────
# Source: Vercel Marketplace → Blob storage (private mode).
# Used for scout images once Phase 0 moves off inline data URLs.
# Retention: 7 years minimum (ag records regulatory baseline); archive policy
# set in Blob dashboard.
BLOB_READ_WRITE_TOKEN=

# ── Project-level config ──────────────────────────────────────────────────────
# Default region context for IPM engine threshold lookups and weather API calls.
MHINDU_DEFAULT_REGION=zimbabwe
